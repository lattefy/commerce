generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
}


enum GlobalRole {
  PLATFORM_ADMIN
  NORMAL
}

enum StoreRole {
  OWNER
  EMPLOYEE
}

enum StoreStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProductStatus {
  DRAFT
  AVAILABLE
  UNAVAILABLE
  ARCHIVED
}

enum OrderType {
  PICKUP
  DELIVERY
}

enum OrderStatus {
  PENDING
  PAID
  PREPARING
  READY
  OUT_FOR_DELIVERY
  COMPLETED
  CANCELLED
}

enum LoyaltyEntryType {
  EARN
  REDEEM
  ADJUST
  EXPIRE
}

enum RewardType {
  FIXED_POINTS
  PERCENTAGE_DISCOUNT
  FREE_PRODUCT
}


model User {
  id         String     @id @default(uuid()) @db.Uuid
  authUserId String     @unique @db.Uuid
  email      String     @unique
  phone      String?
  name       String?
  globalRole GlobalRole @default(NORMAL)

  memberships    StoreMembership[]
  requestedStores Store[] @relation("StoreRequests")
  orders Order[]
  loyaltyEntries    LoyaltyLedgerEntry[]
  rewardRedemptions RewardRedemption[]
  addresses Address[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Store {
  id       String @id @default(uuid()) @db.Uuid
  slug     String @unique
  name     String
  branding Json?
  country  String @default("UY")
  currency String @default("UYU")

  // Contacto
  phone     String?
  instagram String?
  website   String?

  // Dirección
  address      String?
  city         String?
  deliveryZone String?

  // Horarios (estructurado: { mon: { open: "09:00", close: "18:00", closed: false }, ... })
  schedule Json?

  description String?

  status StoreStatus @default(PENDING)

  allowsPickup   Boolean @default(true)
  allowsDelivery Boolean @default(false)

  pickupTime  String? 
  deliveryTime String?

  requestedByUserId String? @db.Uuid
  requestedBy       User?   @relation("StoreRequests", fields: [requestedByUserId], references: [id])

  memberships     StoreMembership[]
  categories      Category[]
  products        Product[]
  orders Order[]
  loyaltySettings   StoreLoyaltySettings?
  loyaltyEntries    LoyaltyLedgerEntry[]
  rewards           Reward[]
  rewardRedemptions RewardRedemption[]
  paymentSettings StorePaymentSettings?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StoreMembership {
  id      String    @id @default(uuid()) @db.Uuid
  userId  String    @db.Uuid
  storeId String    @db.Uuid
  role    StoreRole

  // Employee permissions (owners can be treated as “all true” in logic later)
  canManageProducts  Boolean @default(false)
  canManageOrders    Boolean @default(false)
  canManageLoyalty   Boolean @default(false)
  canManageEmployees Boolean @default(false)
  canViewAnalytics   Boolean @default(false)
  canManageOperations Boolean @default(false)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, storeId])
  @@index([storeId])
  @@index([userId])
}

model Category {
  id       String  @id @default(uuid()) @db.Uuid
  storeId  String  @db.Uuid
  parentId String? @db.Uuid

  name        String
  description String?
  sortOrder   Int     @default(0)

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  parent   Category? @relation("CategoryChildren", fields: [parentId], references: [id])
  children Category[] @relation("CategoryChildren")

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
}

model Product {
  id         String  @id @default(uuid()) @db.Uuid
  storeId    String  @db.Uuid
  categoryId String? @db.Uuid

  name        String
  description String?
  status      ProductStatus @default(DRAFT)
  sortOrder   Int           @default(0)

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  portions ProductPortion[]
  extras   ProductExtra[]
  images   ProductImage[]
  orderItems OrderItem[]
  rewards Reward[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
  @@index([categoryId])
}

model ProductPortion {
  id        String @id @default(uuid()) @db.Uuid
  productId String @db.Uuid

  name      String
  price     Int
  stock     Int     @default(-1)
  isDefault Boolean @default(false)
  sortOrder Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
}

model ProductExtra {
  id        String @id @default(uuid()) @db.Uuid
  productId String @db.Uuid

  name      String
  price     Int
  maxQty    Int     @default(1)
  sortOrder Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  orderItemExtras OrderItemExtra[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
}

model ProductImage {
  id        String @id @default(uuid()) @db.Uuid
  productId String @db.Uuid

  url       String
  altText   String?
  sortOrder Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
}

model Order {
  id      String @id @default(uuid()) @db.Uuid
  storeId String @db.Uuid
  userId  String @db.Uuid

  status     OrderStatus @default(PENDING)
  orderType  OrderType  @default(PICKUP)
  total      Int
  notes      String?

  mpPaymentId String?

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Restrict)

  items OrderItem[]
  loyaltyEntries    LoyaltyLedgerEntry[]
  rewardRedemptions RewardRedemption[]

  addressId String? @db.Uuid
  address   Address? @relation(fields: [addressId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
  @@index([userId])
}

model OrderItem {
  id      String @id @default(uuid()) @db.Uuid
  orderId String @db.Uuid

  productId   String  @db.Uuid
  productName String
  portionId   String  @db.Uuid
  portionName String
  unitPrice   Int
  quantity    Int     @default(1)
  
  extras OrderItemExtra[]

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  portion ProductPortion @relation(fields: [portionId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@index([orderId])
}

model OrderItemExtra {
  id          String @id @default(uuid()) @db.Uuid
  orderItemId String @db.Uuid

  extraId   String @db.Uuid
  extraName String
  unitPrice Int
  quantity  Int    @default(1)

  orderItem  OrderItem   @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  extra      ProductExtra @relation(fields: [extraId], references: [id], onDelete: Restrict)

  @@index([orderItemId])
}

model StoreLoyaltySettings {
  id      String @id @default(uuid()) @db.Uuid
  storeId String @unique @db.Uuid

  pesosPerPoint    Int  @default(20)
  maxPointsPerOrder Int?
  pointsExpiryDays  Int?

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LoyaltyLedgerEntry {
  id      String @id @default(uuid()) @db.Uuid
  storeId String @db.Uuid
  userId  String @db.Uuid

  type      LoyaltyEntryType
  points    Int
  expiresAt DateTime?

  orderId     String? @db.Uuid
  redemptionId String? @db.Uuid

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  redemption RewardRedemption? @relation(fields: [redemptionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([storeId, userId])
  @@index([orderId])
}

model Reward {
  id      String @id @default(uuid()) @db.Uuid
  storeId String @db.Uuid

  name          String
  description   String?
  type          RewardType
  pointsCost    Int
  discountValue Int        @default(0)
  isActive      Boolean    @default(true)

  productId String?  @db.Uuid
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  store       Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  redemptions RewardRedemption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
  @@index([productId])
}

model RewardRedemption {
  id       String @id @default(uuid()) @db.Uuid
  storeId  String @db.Uuid
  userId   String @db.Uuid
  rewardId String @db.Uuid
  orderId  String? @db.Uuid

  store  Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  reward Reward @relation(fields: [rewardId], references: [id], onDelete: Restrict)
  order  Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  ledgerEntries LoyaltyLedgerEntry[]

  createdAt DateTime @default(now())

  @@index([storeId, userId])
}

model StorePaymentSettings {
  id      String @id @default(uuid()) @db.Uuid
  storeId String @unique @db.Uuid

  mpAccessToken  String
  mpRefreshToken String?
  mpUserId       String?
  mpPublicKey    String?
  isConnected    Boolean @default(false)

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Address {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid

  label   String  // "Casa", "Trabajo"
  street  String  // "Luis Alberto de Herrera 1234"
  details String? // "Apto 3B, timbre roto"

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}